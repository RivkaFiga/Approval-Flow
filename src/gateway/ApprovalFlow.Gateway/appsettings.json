{
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "OpenTelemetry": {
    "OtlpEndpoint": ""
  },
  "Jwt": {
    "Issuer": "approvalflow-dev",
    "Audience": "approvalflow-gateway",
    "SigningKey": "development-signing-key-please-override-in-production-32bytes+"
  },
  "RateLimit": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "ReverseProxy": {
    "Routes": {
      "status-route": {
        "ClusterId": "notification",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/status/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "notification": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5106/"
          }
        }
      }
    }
  }
}
